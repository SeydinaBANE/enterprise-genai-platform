# ─── LLM Gateway ────────────────────────────────────────────────────────────
# OpenRouter API key — https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Default model (OpenRouter model ID)
LLM_MODEL=openai/gpt-4o-mini
EMBEDDING_MODEL=openai/text-embedding-3-small

# ─── Vector Store ────────────────────────────────────────────────────────────
# Local ChromaDB (default)
CHROMA_PERSIST_DIR=./data/chroma

# Azure AI Search (prod — leave blank for local dev)
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=genai-platform

# ─── Security ────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change_me_in_production_use_strong_random_key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Azure Content Safety (optional — guardrails fallback used if blank)
AZURE_CONTENT_SAFETY_ENDPOINT=
AZURE_CONTENT_SAFETY_API_KEY=

# ─── Observability ───────────────────────────────────────────────────────────
# OpenTelemetry collector endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=genai-platform

# ─── API ─────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ─── MCP ─────────────────────────────────────────────────────────────────────
MCP_SERVER_PORT=8001

# ─── Azure (prod only) ───────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
